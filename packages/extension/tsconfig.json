{
  "compilerOptions": {
    "baseUrl": "../..",
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "paths": {
      "@bb-browser/shared": ["packages/shared/src/index.ts"]
    },
    "types": ["chrome", "node"],
    "outDir": "dist",
    "rootDir": "../..",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": false,
    "noEmit": true
  },
  "include": ["src"]
}
